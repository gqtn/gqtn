{
    "output": "eDP-1",
    "layer": "top",
    "position": "top",
    "height": 25, // Altura aproximada para acomodar o tamanho de fonte 12pt do Polybar
    "margin": "0 0 0 0",
    "spacing": 3,

    // Layout da Barra
    "modules-left": [
        "sway/workspaces",
        "sway/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/updates",
        "custom/separator",
        "pulseaudio",
        "custom/separator",
        "memory",
        "custom/separator",
        "cpu",
        "custom/separator",
        "custom/wlan0",
        "custom/separator",
        "custom/eth0",
        "custom/separator",
        "battery",
        "custom/separator",
        "group/powermenu"
    ],

    // MГ“DULOS DA ESQUERDA (Sway Nativo)
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },
    "sway/window": {
        "max-length": 60,
        "format": "{title}"
    },

    // MГ“DULO CENTRAL
    "clock": {
        "interval": 1,
        "format": "{:%H:%M}",
        "format-alt": "{:%d-%m-%Y %H:%M:%S}",
        "tooltip": false
    },

    // SEPARADOR CUSTOMIZADO (Replica o separator = | do Polybar)
    "custom/separator": {
        "format": "<span color='#707880'>|</span>",
        "tooltip": false
    },

    // MГ“DULOS DA DIREITA
    "custom/updates": {
        "exec": "$HOME/.config/waybar/updates.sh",
        "interval": 5,
        "format": "<span color='#6CC188'>у°Ј‡  </span>{}",
        "tooltip": false
    },
    "pulseaudio": {
        "scroll-step": 10,
        "format": "<span color='#F0B67F'>пЂЁ  </span>{volume}%",
        "format-muted": "<span color='#707880'>muted</span>",
        // Altera o estado do Mute ao clicar com o botГЈo esquerdo
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle", 
        "on-click-right": "pavucontrol",
        "tooltip": false
    },
    "memory": {
        "interval": 2,
        "format": "<span color='#C7EFCF'>ої…  </span>{}%",
        "tooltip": false
    },
    "cpu": {
        "interval": 2,
        "format": "<span color='#FE5F55'>п‹›  </span>{usage}%",
        "tooltip": false
    },
    "custom/wlan0": {
        "exec": "$HOME/.config/waybar/wifi.sh",
        "interval": 5,
        "format": "<span color='#B56F90'>п‡« </span> {}",
        "on-click": "nm-connection-editor",
        "tooltip": false
    },
    "custom/eth0": {
        "exec": "$HOME/.config/waybar/eth.sh",
        "interval": 5,
        "format": "<span color='#009C8C'>у°€Ђ </span> {}",
        "on-click": "nm-connection-editor",
        "tooltip": false
    },
    "battery": {
        "interval": 5,
        "states": {
            "good": 94,
            "critical": 5
        },
        "format": "{icon} {capacity}%",
        "format-charging": "п‰Ђ  ",
        "format-full": "<span color='#51FA7B'>п‰Ђ </span>",
        "format-critical": "<span color='#FF5555'>Warning!! п‰„ </span> {capacity}%",
        "format-icons": [
            "<span color='#FF5555'>п‰„ </span>",
            "<span color='#FF5555'>п‰ѓ </span>",
            "<span color='#cfdae1'>п‰‚ </span>",
            "<span color='#cfdae1'>п‰Ѓ </span>",
            "<span color='#cfdae1'>п‰Ђ </span>"
        ],
        "tooltip": false
    },

    // MENU DE ENERGIA (Estilo Gaveta/Drawer)
    "group/powermenu": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": false // Expande para a esquerda
        },
        "modules": [
            "custom/power-icon",
            "custom/shutdown",
            "custom/reboot"
        ]
    },
    "custom/power-icon": {
        "format": "<span color='#FFFFFF'>вЏ» </span>",
        "tooltip": false
    },
    "custom/shutdown": {
        "format": "Shut Down",
        "on-click": "systemctl poweroff",
        "tooltip": false
    },
    "custom/reboot": {
        "format": "Reboot",
        "on-click": "systemctl reboot",
        "tooltip": false
    }
}
